<templateSet group="Armeria">
  <template name="armroute-java" key="live.template.annotated.route.method.description" resource-bundle="messages.ArmeriaBundle" value="@com.linecorp.armeria.server.annotation.Get(&quot;$PATH$&quot;)&#10;public $RETURN_TYPE$ $NAME$($PARAMS$) {&#10;    return $END$&quot;&quot;;&#10;}" description="Annotated Armeria route method" toReformat="true" toShortenFQNames="true">
    <variable name="PATH" expression="" defaultValue="&quot;/&quot;" alwaysStopAt="true"/>
    <variable name="RETURN_TYPE" expression="" defaultValue="String" alwaysStopAt="true"/>
    <variable name="NAME" expression="" defaultValue="handler" alwaysStopAt="true"/>
    <variable name="PARAMS" expression="" defaultValue="" alwaysStopAt="true"/>
    <context><option name="JAVA_DECLARATION" value="true"/></context>
  </template>
  <template name="armsrv-java" key="live.template.server.builder.description" resource-bundle="messages.ArmeriaBundle" value="com.linecorp.armeria.server.Server.builder()&#10;      .http($PORT$)&#10;      .annotatedService(new $SERVICE$())&#10;      .build()&#10;      .start()&#10;      .join();" description="Armeria Server.builder skeleton" toReformat="true" toShortenFQNames="true">
    <variable name="PORT" expression="" defaultValue="8080" alwaysStopAt="true"/>
    <variable name="SERVICE" expression="completeSmart()" defaultValue="MyService" alwaysStopAt="true"/>
    <context><option name="JAVA_STATEMENT" value="true"/></context>
  </template>
  <template name="armwc-java" key="live.template.webclient.decorator.description" resource-bundle="messages.ArmeriaBundle" value="com.linecorp.armeria.client.WebClient.builder(&quot;$URI$&quot;)&#10;         .decorator(com.linecorp.armeria.client.logging.LoggingClient.newDecorator())&#10;         .build();" description="Armeria WebClient with LoggingClient decorator" toReformat="true" toShortenFQNames="true">
    <variable name="URI" expression="" defaultValue="&quot;http://localhost:8080&quot;" alwaysStopAt="true"/>
    <context><option name="JAVA_STATEMENT" value="true"/></context>
  </template>
</templateSet>
