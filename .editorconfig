root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
ktlint_code_style = ktlint_official

# IntelliJ fixture tests use testName_scenario style (JUnit3-style method names).
[**/src/test/**/*.{kt,kts}]
ktlint_standard_function-naming = disabled

[**/src/fastTest/**/*.{kt,kts}]
ktlint_standard_function-naming = disabled

[**/src/testFixtures/**/*.{kt,kts}]
ktlint_standard_function-naming = disabled
